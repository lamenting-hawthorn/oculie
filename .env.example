# Polymarket
# Required for live trading:
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
# Signature type: 0=MetaMask/EOA, 1=Email/Magic wallet, 2=Browser proxy (default: 0)
POLYMARKET_SIGNATURE_TYPE=0
# Optional — derived automatically from private key if blank:
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WhatsApp (optional)
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_RECIPIENT=

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# Trading defaults (override via dashboard Settings screen)
PAPER_MODE=true
